# Google Identity Services (OAuth client ID for sign-in)
# Create at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=

# Google Maps JavaScript API + Places
# Same console, "Create credentials -> API key". Restrict by HTTP referrer.
VITE_GOOGLE_MAPS_API_KEY=

# Gemini API key
# Create at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Optional: Gemini model override (default gemini-2.5-flash)
VITE_GEMINI_MODEL=gemini-2.5-flash
